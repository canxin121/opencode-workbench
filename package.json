{
  "name": "opencode-workbench",
  "version": "0.3.2",
  "description": "Branch sandboxes for parallel OpenCode development",
  "type": "module",
  "opencodeStudio": {
    "manifest": "dist/studio.manifest.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canxin121/opencode-workbench.git"
  },
  "homepage": "https://github.com/canxin121/opencode-workbench",
  "bugs": {
    "url": "https://github.com/canxin121/opencode-workbench/issues"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "git",
    "worktree",
    "github",
    "gh",
    "fork"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.6",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "prepack": "bun run typecheck && bun run build",
    "pack:check": "npm pack --dry-run",
    "publish:check": "bun run prepack && npm pack --dry-run",
    "selfcheck": "bun script/selfcheck.ts",
    "studio:bridge:selfcheck": "bun script/studio-bridge-selfcheck.ts",
    "lint": "bunx eslint . --ext .ts",
    "lint:fix": "bunx eslint . --ext .ts --fix"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "*",
    "@types/node": "^25.0.9",
    "bun-types": "^1.3.6",
    "eslint": "^9.39.2",
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
